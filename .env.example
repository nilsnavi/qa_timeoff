# =====================================================================
# Single source of truth for `docker compose` deployment.
# Copy this file to `.env` and adjust values before `docker compose up`.
# =====================================================================

# --- Exposed ports on the host machine ---
APP_PORT=8080         # nginx (frontend + /api proxy) -> http://localhost:8080
BACKEND_PORT=3000     # direct NestJS port (optional, useful for debugging)
POSTGRES_PORT=5432    # host-mapped DB port (set empty/change if 5432 is busy)

# --- PostgreSQL ---
POSTGRES_DB=qa_timeoff
POSTGRES_USER=qa_timeoff
POSTGRES_PASSWORD=qa_timeoff

# --- Backend (NestJS) ---
# Use a long random string in any non-local environment (32+ chars).
JWT_SECRET=replace-me-with-a-long-random-secret-32-chars-min
# JWT token lifetime (default: 24h). Examples: 15m, 7d, 30d.
JWT_EXPIRATION=24h

# --- Auth mode ---
# Основной режим: web (email + пароль). Поддерживаются: web | telegram | both
AUTH_MODE=web
# Включить вход через Telegram Mini App (требует TELEGRAM_BOT_TOKEN)
ENABLE_TELEGRAM_AUTH=false
# Token from @BotFather. Required only if ENABLE_TELEGRAM_AUTH=true.
TELEGRAM_BOT_TOKEN=
# Set to "true" on the first launch to seed demo users/teams/requests.
RUN_SEED=false
# Telegram ID of the first admin (optional). If set, the user with this ID gets ADMIN role.
ADMIN_TELEGRAM_ID=

# --- Caddy / HTTPS ---
# Set to your domain (e.g., qatimeoff.ru) for automatic HTTPS via Let's Encrypt.
# Leave empty for local HTTP-only testing.
CADDY_DOMAIN=
# Email for Let's Encrypt certificate notifications (required with CADDY_DOMAIN).
CADDY_EMAIL=

# --- CORS / URLs ---
FRONTEND_URL=http://localhost:8080
CORS_ORIGIN=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# --- Rate limiting ---
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# --- Logging ---
LOG_LEVEL=info
LOG_DIR=logs

# --- Cache / Redis ---
CACHE_TTL=300
REDIS_URL=redis://redis:6379

# --- Database backup ---
# How many days to keep backups (default: 30)
BACKUP_RETENTION_DAYS=30
# Cron schedule for backups (default: daily at 3am)
BACKUP_SCHEDULE=0 3 * * *

# --- Frontend (Vite, build-time) ---
# Keep "/api" — nginx in front proxies /api -> backend:3000
VITE_API_URL=/api

# --- Uptime Kuma (monitoring dashboard) ---
UPTIME_KUMA_PORT=3001

# --- Sentry (error tracking for frontend) ---
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production

# --- SMTP / Email (обязательно для production) ---
# В production-режиме эти 4 переменные обязательны — без них
# backend не стартует (env.validation.ts бросит ошибку).
# Для локального запуска docker compose можно оставить пустыми.
SMTP_HOST=smtp.yandex.ru
# Порт: 465 для SSL, 587 для STARTTLS
SMTP_PORT=465
# true для порта 465, false для 587
SMTP_SECURE=true
SMTP_USER=noreply@yourdomain.ru
SMTP_PASS=
# Формат: "QA TimeOff <noreply@yourdomain.ru>" или просто email
EMAIL_FROM=QA TimeOff <noreply@yourdomain.ru>

# --- HTTP Proxy (for Telegram API behind corporate firewall) ---
# Only needed if the backend cannot reach Telegram API directly.
# Leave empty (or remove) if no proxy is required.
# HTTP_PROXY=http://host.docker.internal:10808
# HTTPS_PROXY=http://host.docker.internal:10808
