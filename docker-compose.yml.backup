services:
  postgres:
    image: postgres:16-alpine
    container_name: qa-timeoff-postgres
    restart: unless-stopped
    environment:
      POSTGRES_DB: ${POSTGRES_DB:-qa_timeoff}
      POSTGRES_USER: ${POSTGRES_USER:-qa_timeoff}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-qa_timeoff}
    ports:
      - "${POSTGRES_PORT:-5432}:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-qa_timeoff} -d ${POSTGRES_DB:-qa_timeoff}"]
      interval: 5s
      timeout: 5s
      retries: 10
      start_period: 10s
    networks:
      - qa-timeoff-net

  redis:
    image: redis:7-alpine
    container_name: qa-timeoff-redis
    restart: unless-stopped
    ports:
      - "${REDIS_PORT:-6379}:6379"
    volumes:
      - redis-data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    networks:
      - qa-timeoff-net

  backend:
    build:
      context: .
      dockerfile: apps/backend/Dockerfile
    container_name: qa-timeoff-backend
    restart: unless-stopped
    environment:
      NODE_ENV: production
      API_PORT: 3000
      DATABASE_URL: "postgresql://${POSTGRES_USER:-qa_timeoff}:${POSTGRES_PASSWORD:-qa_timeoff}@postgres:5432/${POSTGRES_DB:-qa_timeoff}?schema=public"
      JWT_SECRET: ${JWT_SECRET:?Set JWT_SECRET in .env}
      TELEGRAM_BOT_TOKEN: ${TELEGRAM_BOT_TOKEN:?Set TELEGRAM_BOT_TOKEN in .env}
      FRONTEND_URL: ${FRONTEND_URL:-http://localhost:8080}
      CORS_ORIGIN: ${CORS_ORIGIN:-http://localhost:8080}
      ALLOWED_ORIGINS: ${ALLOWED_ORIGINS:-http://localhost:8080,http://localhost:5173}
      RATE_LIMIT_TTL: ${RATE_LIMIT_TTL:-60}
      RATE_LIMIT_MAX: ${RATE_LIMIT_MAX:-100}
      LOG_LEVEL: ${LOG_LEVEL:-info}
      LOG_DIR: ${LOG_DIR:-logs}
      CACHE_TTL: ${CACHE_TTL:-300}
      REDIS_URL: ${REDIS_URL:-redis://redis:6379}
      # Set RUN_SEED=true in your .env to apply prisma/seed.ts on first start
      RUN_SEED: ${RUN_SEED:-false}
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    expose:
      - "3000"
    ports:
      - "${BACKEND_PORT:-3000}:3000"
    healthcheck:
      test:
        - CMD-SHELL
        - node -e "fetch('http://127.0.0.1:3000/health').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 20s
    networks:
      - qa-timeoff-net

  frontend:
    build:
      context: .
      dockerfile: apps/frontend/Dockerfile
      args:
        VITE_API_URL: ${VITE_API_URL:-/api}
    container_name: qa-timeoff-frontend
    restart: unless-stopped
    depends_on:
      - backend
    expose:
      - "80"
    healthcheck:
      test:
        - CMD-SHELL
        - node -e "fetch('http://127.0.0.1:3000/health').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 20s
    networks:
      - qa-timeoff-net

  nginx:
    image: nginx:1.27-alpine
    container_name: qa-timeoff-nginx
    restart: unless-stopped
    depends_on:
      - backend
      - frontend
    ports:
      - "${APP_PORT:-8080}:80"
    volumes:
      - ./infra/nginx.conf:/etc/nginx/conf.d/default.conf:ro
    networks:
      - qa-timeoff-net

volumes:
  postgres-data:
  redis-data:

networks:
  qa-timeoff-net:
    driver: bridge
