# ============================================================
# СЕКРЕТЫ — сгенерировать перед деплоем:
#   JWT_SECRET:        openssl rand -hex 32
#   POSTGRES_PASSWORD: openssl rand -base64 24
# ============================================================

NODE_ENV=development
API_PORT=3000
# Пароль должен совпадать с POSTGRES_PASSWORD ниже
DATABASE_URL=postgresql://qa_timeoff:REPLACE_WITH_YOUR_PASSWORD@localhost:5432/qa_timeoff?schema=public
# Сгенерировать: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# Auth mode: web | telegram | both
AUTH_MODE=web
ENABLE_TELEGRAM_AUTH=false
# Необязателен при AUTH_MODE=web. Обязателен только для Telegram Mini App.
TELEGRAM_BOT_TOKEN=

FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
LOG_LEVEL=info
LOG_DIR=logs
CACHE_TTL=300
REDIS_URL=redis://localhost:6379
ADMIN_TELEGRAM_ID=

# SMTP / Email
# Сгенерировать: openssl rand -base64 24
POSTGRES_PASSWORD=

SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@yourdomain.ru
SMTP_PASS=
EMAIL_FROM="QA TimeOff <noreply@yourdomain.ru>"
