generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  LEAD
  MANAGER
  ADMIN
}

enum RequestStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum BalanceOperationType {
  ADD
  WRITE_OFF
  MANUAL_CORRECTION
  EXPIRED
  IMPORT_INITIAL_BALANCE
  IMPORT_BALANCE_ADJUSTMENT
}

enum VacationType {
  ANNUAL
  UNPAID
  SICK_LEAVE
  OTHER
}


enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum ScheduleType {
  STANDARD_5_2
  SHIFT_2_2
  SHIFT_3_3
  SHIFT_4_4
  NIGHT_SHIFT
  FLEXIBLE
  CUSTOM
}

enum Plan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum ImportType {
  USERS
  TEAMS
  BALANCES
  SCHEDULES
}

enum ImportStatus {
  PENDING
  VALIDATING
  READY
  PROCESSING
  SUCCESS
  PARTIAL_SUCCESS
  FAILED
  CANCELLED
}

model Organization {
  id                 String             @id @default(cuid())
  name               String
  slug               String             @unique
  plan               Plan               @default(FREE)
  seatsLimit         Int                @default(10)
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  trialEndsAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  users              User[]
  teams              Team[]
  workSchedules      WorkSchedule[]
}

model CompanySettings {
  id                        String   @id @default(cuid())
  companyName               String   @default("QA TimeOff")
  logoUrl                   String?
  timezone                  String   @default("Europe/Moscow")
  locale                    String   @default("ru")
  dateFormat                String   @default("DD.MM.YYYY")
  workWeekDays              Int      @default(5)
  workingHoursPerDay        Int      @default(8)
  workingDaysPerWeek        Int      @default(5)
  defaultAnnualHours        Int      @default(1760)
  minimumTeamCoveragePercent    Int  @default(70)
  minimumBalanceHours       Int      @default(0)
  approvalPolicy            String   @default("MANAGER_OR_ADMIN")
  requireRejectComment      Boolean  @default(true)
  blockApprovalOnCoverageRisk Boolean @default(false)
  countPendingAsCoverageRisk   Boolean @default(true)
  allowNegativeBalance      Boolean  @default(false)
  emailNotificationsEnabled Boolean  @default(true)
  telegramNotificationsEnabled Boolean @default(false)
  inAppNotificationsEnabled Boolean  @default(true)
  notifyNewRequest           Boolean @default(true)
  notifyApproval             Boolean @default(true)
  notifyRejection            Boolean @default(true)
  notifyLowBalance           Boolean @default(false)
  notifyCoverageRisk         Boolean @default(true)
  notifyOverdueRequests      Boolean @default(true)
  smtpHost                   String?
  smtpPort                   Int?
  smtpUser                   String?
  smtpFrom                   String?
  smtpPassword               String?
  telegramBotToken           String?
  telegramBotEnabled         Boolean  @default(false)
  updatedById                String?
  updatedBy                  User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model User {
  id                String             @id @default(cuid())
  organizationId    String
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  telegramId        String?
  passwordHash      String?
  mustChangePassword Boolean             @default(false)
  fullName          String
  username          String?
  email             String?            @unique
  position          String?
  hourlyRate        Int                @default(0)
  currency          String             @default("RUB")
  role              Role               @default(EMPLOYEE)
  roleId            String?
  roleRef           RoleModel?         @relation(fields: [roleId], references: [id], onDelete: SetNull)
  teamId            String?
  team             Team?              @relation("TeamMembers", fields: [teamId], references: [id], onDelete: SetNull)
  teamLead         Team?              @relation("TeamLead")
  managerId        String?
  manager          User?              @relation("UserManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports     User[]             @relation("UserManager")
  isActive              Boolean  @default(true)
  notifyRequestUpdates  Boolean  @default(true)
  notifyTeamRequests    Boolean  @default(true)
  notifyEmailDigest     Boolean  @default(false)
  lastLoginAt           DateTime?
  timeBalance       TimeBalance?
  balanceOperations BalanceOperation[] @relation("BalanceOperationUser")
  createdOperations BalanceOperation[] @relation("BalanceOperationCreator")
  calendarEvents    CalendarEvent[]    @relation("CalendarEventUser")
  leaveRequests     LeaveRequest[]     @relation("LeaveRequestUser")
  leaveApprovals    LeaveRequest[]     @relation("LeaveRequestApprover")
  timeOffRequests   TimeOffRequest[]   @relation("TimeOffRequestUser")
  timeOffApprovals  TimeOffRequest[]   @relation("TimeOffRequestApprover")
  vacationRequests  VacationRequest[]  @relation("VacationRequestUser")
  invitesSent       Invite[]           @relation("InvitedBy")
  vacationApprovals VacationRequest[]  @relation("VacationRequestApprover")
  notifications     Notification[]
  positionHistory   PositionHistory[]  @relation("PositionHistoryUser")
  positionChangedBy PositionHistory[]  @relation("PositionHistoryChanger")
  overtimes         Overtime[]
  createdOvertimes  Overtime[]         @relation("OvertimeCreator")
  cancelledOvertimes Overtime[]        @relation("OvertimeCanceller")
  kpiPeriods        KpiPeriod[]
  auditLogs         AuditLog[]
  importJobs        ImportJob[]
  workSchedule      WorkSchedule?
  updatedCompanySettings CompanySettings[]
  refreshTokens     RefreshToken[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([organizationId])
  @@index([email])
}

model PositionHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("PositionHistoryUser", fields: [userId], references: [id], onDelete: Cascade)
  position  String
  changedBy String
  changer   User     @relation("PositionHistoryChanger", fields: [changedBy], references: [id], onDelete: Restrict)
  changedAt DateTime @default(now())
}

enum OvertimeStatus {
  APPROVED
  CANCELLED
}

model Overtime {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  hours           Int
  date            DateTime
  reason          String
  multiplier      Float          @default(1.0)
  calculatedCost  Float?
  status          OvertimeStatus @default(APPROVED)
  cancelledById   String?
  cancelledBy     User?          @relation("OvertimeCanceller", fields: [cancelledById], references: [id], onDelete: SetNull)
  cancelledAt     DateTime?
  createdById     String
  createdBy       User           @relation("OvertimeCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime       @default(now())
}

model Team {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  name           String
  description    String?
  leadId         String?   @unique
  lead           User?     @relation("TeamLead", fields: [leadId], references: [id], onDelete: SetNull)
  isActive       Boolean      @default(true)
  users          User[]       @relation("TeamMembers")
  invites        Invite[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

model TimeBalance {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balanceHours    Int      @default(0)
  totalAddedHours Int      @default(0)
  totalUsedHours  Int      @default(0)
  updatedAt       DateTime @updatedAt
}

model WorkSchedule {
  id               String       @id @default(cuid())
  userId           String       @unique
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  scheduleType     ScheduleType @default(STANDARD_5_2)
  workingDays      Int[]        @default([1, 2, 3, 4, 5])
  hoursPerDay      Int          @default(8)
  shiftStartTime   String?
  shiftEndTime     String?
  cycleStartDate   DateTime?
  cycleWorkDays    Int?
  cycleRestDays    Int?
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([organizationId])
  @@index([userId])
}

model BalanceOperation {
  id            String               @id @default(cuid())
  userId        String
  user          User                 @relation("BalanceOperationUser", fields: [userId], references: [id], onDelete: Cascade)
  operationType BalanceOperationType
  hours         Int
  reason        String
  createdById   String
  createdBy     User                 @relation("BalanceOperationCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime             @default(now())
}

model TimeOffRequest {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation("TimeOffRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime
  hours           Int
  reason          String
  comment         String?
  status          RequestStatus @default(PENDING)
  approverId      String?
  approver        User?         @relation("TimeOffRequestApprover", fields: [approverId], references: [id], onDelete: SetNull)
  approverComment String?
  approvedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model VacationRequest {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation("VacationRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  startDate       DateTime
  endDate         DateTime
  daysCount       Int
  vacationType    VacationType
  status          RequestStatus @default(PENDING)
  comment         String?
  approverId      String?
  approver        User?         @relation("VacationRequestApprover", fields: [approverId], references: [id], onDelete: SetNull)
  approverComment String?
  approvedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model KpiPeriod {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month               Int
  year                Int
  plannedHours        Int      @default(0)
  actualWorkedHours   Int      @default(0)
  overtimeHours       Int      @default(0)
  approvedRequests    Int      @default(0)
  rejectedRequests    Int      @default(0)
  cancelledRequests   Int      @default(0)
  responseTimeAvgHours Float   @default(0)
  workloadScore       Float    @default(0)
  reliabilityScore    Float    @default(0)
  kpiScore            Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId, month, year])
}

enum LeaveRequestType {
  TIME_OFF
  VACATION
}

/// Модель LeaveRequest используется для унифицированного API заявок
/// (/leave-requests). Новая заявка дублируется в LeaveRequest + TimeOffRequest
/// или VacationRequest в зависимости от типа. Миграция добавлена в
/// 20260625100100_migrate_leave_requests.
model LeaveRequest {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation("LeaveRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  teamId          String?
  type            LeaveRequestType
  dateFrom        DateTime
  dateTo          DateTime?
  hours           Int
  reason          String
  comment         String?
  status          RequestStatus    @default(PENDING)
  approverId      String?
  approver        User?            @relation("LeaveRequestApprover", fields: [approverId], references: [id], onDelete: SetNull)
  approverComment String?
  approvedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId])
  @@index([teamId])
  @@index([status])
  @@index([userId, createdAt])
  @@index([teamId, createdAt])
}

enum CalendarEventType {
  VACATION
  TIME_OFF
  SICK_LEAVE
  HOLIDAY
}

enum CalendarEventStatus {
  CREATED
  PENDING
  APPROVED
  ACTIVE
  COMPLETED
  CANCELLED
}

model CalendarEvent {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation("CalendarEventUser", fields: [userId], references: [id], onDelete: Cascade)
  teamId    String?
  type      CalendarEventType
  startDate DateTime
  endDate   DateTime
  status    CalendarEventStatus  @default(PENDING)
  comment   String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([userId])
  @@index([teamId])
  @@index([startDate, endDate])
  @@index([type, startDate])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Invite {
  id         String       @id @default(cuid())
  email      String
  role       Role         @default(EMPLOYEE)
  teamId     String?
  team       Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  tokenHash  String       @unique
  status     InviteStatus @default(PENDING)
  expiresAt  DateTime
  invitedById String
  invitedBy  User         @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedAt DateTime?
  createdAt  DateTime     @default(now())

  @@index([email])
  @@index([status])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation(fields: [actorId], references: [id], onDelete: Restrict)
  actorName  String?
  actorRole  String?
  action     String
  entityType String
  entityId   String?
  entityName String?
  result     String   @default("SUCCESS")
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  payload    Json?
  createdAt  DateTime @default(now())
}

model ImportJob {
  id                String       @id @default(cuid())
  type              ImportType
  status            ImportStatus @default(PENDING)
  fileName          String
  originalFilePath  String?
  errorFilePath     String?
  createdById       String
  createdBy         User         @relation(fields: [createdById], references: [id], onDelete: Restrict)
  totalRows         Int          @default(0)
  validRows         Int          @default(0)
  createdRows       Int          @default(0)
  updatedRows       Int          @default(0)
  skippedRows       Int          @default(0)
  errorRows         Int          @default(0)
  startedAt         DateTime?
  finishedAt        DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  errors            ImportError[]
}

model ImportError {
  id          String    @id @default(cuid())
  importJobId String
  importJob   ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  rowNumber   Int
  field       String?
  message     String
  rawValue    String?
  rawData     Json?
  createdAt   DateTime  @default(now())
}

model RoleModel {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  description String           @default("")
  isSystem    Boolean          @default(false)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  description String           @default("")
  groupName   String           @default("")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  rolePermissions RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         RoleModel  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}
